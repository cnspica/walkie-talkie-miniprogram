/* 全局样式 */
page {
  background-color: #12122a;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 14px;
}

.container {
  padding: 16px;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: #1a1a2e;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

/* 通用按钮 */
.btn-primary {
  background: #1D9E75;
  color: #ffffff;
  border: none;
  border-radius: 8px;
  padding: 12px 16px;
  font-size: 14px;
  text-align: center;
}

.btn-secondary {
  background: #2a2a4e;
  color: #888888;
  border: none;
  border-radius: 8px;
  padding: 12px 16px;
  font-size: 14px;
  text-align: center;
}

/* 文字颜色 */
.text-primary { color: #ffffff; }
.text-secondary { color: #888888; }
.text-accent { color: #5DCAA5; }
.text-warning { color: #EF9F27; }
.text-danger { color: #E24B4A; }
.text-info { color: #378ADD; }

/* 字体大小 */
.text-sm { font-size: 12px; }
.text-md { font-size: 14px; }
.text-lg { font-size: 16px; }
.text-xl { font-size: 18px; }
