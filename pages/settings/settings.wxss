/* pages/settings/settings.wxss */
.page-title {
  font-size: 18px;
  font-weight: 500;
  color: #fff;
  margin-bottom: 16px;
}

.settings-group {
  background: #1a1a2e;
  border-radius: 12px;
  padding: 4px 16px;
  margin-bottom: 12px;
}

.group-title {
  font-size: 11px;
  color: #5DCAA5;
  font-weight: 500;
  padding: 12px 0 4px;
  text-transform: uppercase;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 0.5px solid #2a2a4e;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 13px;
  color: #ccc;
}

.setting-value {
  font-size: 13px;
  color: #888;
  font-family: monospace;
}

.info-card {
  background: #1a1a2e;
  border-radius: 12px;
  padding: 16px;
  margin-top: 12px;
}

.info-title {
  font-size: 13px;
  color: #5DCAA5;
  font-weight: 500;
  margin-bottom: 8px;
}

.info-text {
  font-size: 12px;
  color: #888;
  line-height: 1.8;
  margin-bottom: 4px;
}

.text-accent { color: #5DCAA5; }
.text-secondary { color: #888; }
