/* pages/channel/channel.wxss */
.page-title {
  font-size: 18px;
  font-weight: 500;
  color: #fff;
  margin-bottom: 16px;
}

.channel-list {
  margin-bottom: 12px;
}

.channel-item {
  display: flex;
  align-items: center;
  background: #1a1a2e;
  border-radius: 12px;
  padding: 14px;
  margin-bottom: 8px;
  border: 1px solid transparent;
}

.channel-item.active {
  border-color: #5DCAA5;
  background: #1a2a2e;
}

.channel-icon {
  width: 40px;
  height: 40px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 500;
  margin-right: 12px;
}

.icon-acoustic {
  background: #1D9E75;
  color: #fff;
}

.icon-network {
  background: #185FA5;
  color: #fff;
}

.channel-detail {
  flex: 1;
}

.channel-name {
  font-size: 14px;
  color: #fff;
  font-weight: 500;
}

.channel-info-row {
  display: flex;
  justify-content: space-between;
  margin-top: 4px;
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #333;
}

.dot-active {
  background: #5DCAA5;
}

.info-card {
  background: #1a1a2e;
  border-radius: 12px;
  padding: 16px;
  margin-top: 16px;
}

.info-title {
  font-size: 13px;
  color: #5DCAA5;
  font-weight: 500;
  margin-bottom: 8px;
}

.info-text {
  font-size: 12px;
  color: #888;
  line-height: 1.8;
  margin-bottom: 4px;
}

.text-sm { font-size: 12px; }
.text-secondary { color: #888; }
.text-accent { color: #5DCAA5; }
.text-info { color: #378ADD; }
