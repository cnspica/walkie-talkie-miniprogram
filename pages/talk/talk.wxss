/* pages/talk/talk.wxss */
.container {
  padding: 12px;
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #1a1a2e;
  border-radius: 12px;
  padding: 12px 16px;
  margin-bottom: 8px;
}

.channel-info {
  flex: 1;
}

.channel-name {
  font-size: 16px;
  font-weight: 500;
  color: #ffffff;
  display: block;
}

.channel-meta {
  font-size: 11px;
  color: #666666;
  margin-top: 2px;
}

.mode-switch {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #2a2a4e;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mode-indicator {
  width: 14px;
  height: 14px;
  border-radius: 50%;
}

.mode-acoustic {
  border: 1.5px solid #5DCAA5;
}

.mode-network {
  background: #185FA5;
}

.mode-panel {
  background: #2a2a4e;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 8px;
}

.mode-panel-title {
  font-size: 11px;
  color: #5DCAA5;
  font-weight: 500;
  margin-bottom: 8px;
}

.mode-options {
  display: flex;
  gap: 6px;
}

.mode-option {
  flex: 1;
  text-align: center;
  padding: 8px;
  background: #1a1a2e;
  border-radius: 6px;
  color: #888;
  font-size: 12px;
}

.mode-option.active {
  background: #1D9E75;
  color: #fff;
}

.mode-desc {
  display: block;
  font-size: 10px;
  margin-top: 2px;
  opacity: 0.7;
}

.msg-list {
  flex: 1;
  background: #12122a;
  border-radius: 12px;
  padding: 12px;
  margin-bottom: 8px;
  overflow-y: auto;
}

.msg-item {
  margin-bottom: 10px;
}

.msg-self {
  text-align: right;
}

.msg-sender {
  font-size: 10px;
  color: #5DCAA5;
  margin-bottom: 2px;
}

.msg-self .msg-sender {
  color: #378ADD;
}

.msg-bubble {
  display: inline-block;
  background: #2a2a4e;
  color: #cccccc;
  font-size: 13px;
  padding: 6px 10px;
  border-radius: 8px;
  max-width: 75%;
  word-break: break-all;
}

.msg-self .msg-bubble {
  background: #185FA5;
  color: #ffffff;
}

.msg-bubble-system {
  background: transparent;
  color: #888;
  font-style: italic;
  font-size: 12px;
}

.progress-bar {
  width: 120px;
  height: 3px;
  background: #2a2a4e;
  border-radius: 2px;
  margin-top: 4px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #EF9F27;
  border-radius: 2px;
  transition: width 0.1s;
}

.waveform-box {
  background: #1a1a2e;
  border-radius: 12px;
  padding: 12px;
  margin-bottom: 8px;
}

.waveform-canvas {
  width: 100%;
  height: 60px;
  margin-top: 6px;
}

.waveform-info {
  display: flex;
  justify-content: space-between;
  margin-top: 6px;
}

.input-area {
  background: #1a1a2e;
  border-radius: 12px;
  padding: 10px;
}

.input-row {
  display: flex;
  gap: 8px;
  margin-bottom: 8px;
}

.msg-input {
  flex: 1;
  background: #12122a;
  border: 0.5px solid #2a2a4e;
  border-radius: 8px;
  padding: 8px 10px;
  color: #ffffff;
  font-size: 12px;
}

.btn-send {
  background: #185FA5;
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: 0 14px;
  font-size: 12px;
  line-height: 2.2;
}

.btn-send[disabled] {
  opacity: 0.5;
}

.ptt-btn {
  background: #993C1D;
  color: #ffffff;
  border: none;
  border-radius: 40px;
  padding: 14px;
  font-size: 14px;
  font-weight: 500;
  width: 100%;
}

.ptt-btn[disabled] {
  background: #2a2a4e;
  color: #555;
}

.ptt-active {
  background: #D85A30 !important;
  transform: scale(1.02);
}

.text-warning { color: #EF9F27; }
.text-accent { color: #5DCAA5; }
.text-secondary { color: #888888; }
.text-sm { font-size: 12px; }
